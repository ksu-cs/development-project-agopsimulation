export default class FiniteStateManager {
    constructor(vehicle) {
        this.vehicle = vehicle;       // The vehicle or simulation object
        this.currentState = null;     // Currently active state
    }

    // Switch to a new state
    async setState(newState) {
        if (this.currentState && this.currentState.exit) {
            await this.currentState.exit();   // call exit of old state
        }
        this.currentState = newState;
        if (this.currentState && this.currentState.enter) {
            await this.currentState.enter();  // call enter of new state
        }
    }

    // Called every tick to update the current state
    async update(dt) {
        if (this.currentState && this.currentState.update) {
            await this.currentState.update(dt);
        }
    }
}
